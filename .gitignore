# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/
.ruff_cache/
.pytest_cache/

# Env
.env

# Data & ML artifacts (too large for git). Ignore the CONTENTS of the repo-root
# data/ (anchored, so git can still descend) — but keep the small synthetic demo
# dataset, which is intentional and powers demo mode.
/data/*
!/data/synthetic_demo/
ml/experiments/
ml/models/

# IDE
.idea/
.vscode/
*.DS_Store

# Node
node_modules/

# Logs
*.log

# Office lock files
~$*.docx
~$*.xlsx
~$*.pptx
.~lock.*

# NumPy checkpoint artifacts (legacy format — use .pt checkpoints instead)
*.npz

# Model checkpoints (distributed via GitHub Releases)
*.pt
*.pth
*.onnx

# Large data artifacts
*.parquet
*.feather
